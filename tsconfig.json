{
  "compilerOptions": {   
    // Type Checking
    "noImplicitOverride":true,
    "noImplicitAny":true,
    "noImplicitReturns":true,
    "noImplicitThis":true,
    "noUnusedLocals":true,
    "noUnusedParameters": true,
    "preserveConstEnums": true,
    
    // Emit
    "outDir": "./dist",
    "rootDir": "./src",
    "stripInternal": true,
		"removeComments": true,

    // Environment Settings
    "target": "es2022",
    "module": "commonjs",
    "esModuleInterop": true,
    "types": ["node"]
  }
}
