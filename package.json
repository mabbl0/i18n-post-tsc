{
  "name": "i18n-post-tsc",
  "version": "0.1.0",
  "description": "Inject your translations directly into your compiled JS, so you write your TS as if i18n never existed",
  "keywords": [
    "ts",
    "tsc",
    "translation",
    "translate",
    "i18n"
  ],
  "homepage": "https://github.com/mabbl0/post-tsc-i18n#readme",
  "bugs": {
    "url": "https://github.com/mabbl0/post-tsc-i18n/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mabbl0/post-tsc-i18n.git"
  },
  "license": "MIT",
  "author": "mabbl0",
  "type": "commonjs",
  "dependencies": {
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/yargs": "^17.0.35",
    "dts-bundle-generator": "^9.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=25.8.1"
  },
  "files": [
    "./packages/i18n-post-tsc/dist"
  ],
  "types": "./packages/i18n-post-tsc/dist/index.d.ts",
  "main": "./packages/i18n-post-tsc/dist/index.js",
  "bin": "./packages/i18n-post-tsc/dist/bin/i18n-post-tsc.js",
  "scripts": {
    "build": "npm run build:post && npm run build:dyn",
    "build:post": "tsc -p tsconfig.build.i18n-post-tsc.json",
    "build:dyn": "tsc -p tsconfig.build.dynamic-translation-post-tsc.json && npm run build:dyn:dts",
    "build:dyn:dts": "dts-bundle-generator --project tsconfig.dts.dynamic-translation-post-tsc.json --export-referenced-types false --out-file ./packages/dynamic-translation-post-tsc/dist/index.d.ts src/dynamic-translation/index-dynamic-translation.ts",
    "test": "vitest run"
  }
}
